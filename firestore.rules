
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Authentication ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isClubAdmin(clubId) {
      let club = get(/databases/$(database)/documents/clubs/$(clubId)).data;
      return isSignedIn() && (
        club.ownerId == request.auth.uid || 
        request.auth.uid in club.adminIds ||
        isAdmin()
      );
    }

    // --- Validation ---
    function isValidTournament(data) {
      return data.keys().hasOnly(['clubId', 'name', 'status', 'statusHistory', 'startDate', 'endDate', 'minParticipants', 'maxParticipants', 'bracketConfirmed', 'entryFee', 'sport', 'locations', 'categories', 'version', 'createdAt', 'deletedAt', 'description', 'numCourts', 'matchDuration', 'recoveryTime', 'referees', 'isFeatured', 'hasWelcomePack', 'welcomePackDescription', 'requiresSize']) &&
             data.status in ['draft', 'registration_open', 'registration_closed', 'in_progress', 'completed', 'archived'];
    }

    function isValidMatch(data) {
      return data.keys().hasOnly(['tournamentId', 'clubId', 'round', 'bracketPosition', 'nextMatchId', 'isBye', 'byePlayerId', 'courtId', 'court', 'teamA', 'teamB', 'score', 'status', 'scheduledTime', 'actualStartTime', 'actualEndTime', 'durationMinutes', 'version', 'location', 'category', 'categoryId', 'startTime', 'completedAt']) &&
             data.status in ['scheduled', 'live', 'completed'];
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      match /notifications/{notifId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /stats/main {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isClubAdmin(clubId);
    }

    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create: if isSignedIn() && isClubAdmin(request.resource.data.clubId) && isValidTournament(request.resource.data);
      allow update: if isClubAdmin(resource.data.clubId) && isValidTournament(request.resource.data);
      allow delete: if false; // Use soft deletes
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isSignedIn() && isClubAdmin(request.resource.data.clubId) && isValidMatch(request.resource.data);
    }

    match /participants/{participantId} {
      allow read: if true;
      allow create: if (request.resource.data.tournamentId != null) && 
                      exists(/databases/$(database)/documents/tournaments/$(request.resource.data.tournamentId)) &&
                      (request.resource.data.userId == request.auth.uid || isClubAdmin(request.resource.data.clubId));
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isClubAdmin(resource.data.clubId));
    }

    match /courts/{courtId} {
      allow read: if true;
      allow write: if isSignedIn() && isClubAdmin(request.resource.data.clubId);
      
      match /slots/{slotId} {
        allow read: if true;
        allow write: if isSignedIn() && isClubAdmin(get(/databases/$(database)/documents/courts/$(courtId)).data.clubId);
      }
    }

    match /promocodes/{promoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if isSignedIn() && isClubAdmin(request.resource.data.clubId);
    }

    match /checkins/{checkinId} {
      allow read: if isSignedIn() && (isAdmin() || exists(/databases/$(database)/documents/participants/$(resource.data.participantId)));
      allow create: if isSignedIn();
    }
  }
}
