rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Authentication Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Robust Admin Check: Safe against missing user documents
    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && 
             exists(userPath) && 
             get(userPath).data.get('role', 'player') == 'admin';
    }

    // Robust Club Admin Check: Safe against missing club documents
    function isClubAdmin(clubId) {
      let clubPath = /databases/$(database)/documents/clubs/$(clubId);
      return isSignedIn() && (
        (exists(clubPath) && (
          get(clubPath).data.ownerId == request.auth.uid || 
          request.auth.uid in get(clubPath).data.get('adminIds', [])
        )) || isAdmin()
      );
    }

    // --- Validation Helpers ---
    function isValidTournament(data) {
      let allowedStatuses = ['draft', 'registration_open', 'registration_closed', 'in_progress', 'completed', 'archived'];
      return data.keys().hasAll(['clubId', 'name', 'status']) &&
             data.status in allowedStatuses;
    }

    function isValidMatch(data) {
      let allowedStatuses = ['scheduled', 'live', 'completed'];
      return data.keys().hasAll(['tournamentId', 'clubId', 'status', 'teamA', 'teamB']) &&
             data.status in allowedStatuses;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Allow any signed-in user to read profiles (needed for admin check logic)
      allow read: if isSignedIn();
      // Only owner or admin can update
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      match /notifications/{notifId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /stats/main {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isClubAdmin(clubId);
    }

    match /tournaments/{tournamentId} {
      // Global Read for public listings and dashboard
      allow read: if true; 
      allow create: if isSignedIn() && isClubAdmin(request.resource.data.clubId) && isValidTournament(request.resource.data);
      allow update: if isClubAdmin(resource.data.clubId) && isValidTournament(request.resource.data);
      allow delete: if false; 
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isSignedIn() && isClubAdmin(request.resource.data.clubId) && isValidMatch(request.resource.data);
    }

    match /participants/{participantId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                      exists(/databases/$(database)/documents/tournaments/$(request.resource.data.tournamentId)) &&
                      (request.resource.data.userId == request.auth.uid || isClubAdmin(request.resource.data.clubId));
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isClubAdmin(resource.data.clubId));
    }

    match /courts/{courtId} {
      allow read: if true;
      allow write: if isSignedIn() && isClubAdmin(request.resource.data.clubId);
    }

    match /promocodes/{promoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if isSignedIn() && isClubAdmin(request.resource.data.clubId);
    }

    match /checkins/{checkinId} {
      allow read: if isSignedIn() && (isAdmin() || isClubAdmin(resource.data.clubId));
      allow create: if isSignedIn();
    }
  }
}