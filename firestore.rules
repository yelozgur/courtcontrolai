
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email.lower() == 'admin@deneme.com'
      );
    }

    function isClubOwner(clubId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid || isAdmin()
      );
    }

    // User Profiles
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Clubs
    match /clubs/{clubId} {
      allow read: if true; // Public branding access
      allow create: if isSignedIn();
      allow update: if (resource.data.ownerId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Tournaments - Strict List/Read
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create: if isSignedIn(); 
      allow update, delete: if isClubOwner(resource.data.clubId);
    }

    // Matches - Strict List/Write
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isSignedIn() && (
        (resource != null && isClubOwner(resource.data.clubId)) ||
        (resource == null && isClubOwner(request.resource.data.clubId))
      );
    }

    // Participants & Check-ins - Isolated
    match /participants/{participantId} {
      allow read: if isSignedIn() && (
        (resource != null && isClubOwner(resource.data.clubId)) ||
        (resource == null && isClubOwner(request.resource.data.clubId)) ||
        request.auth.token.email.lower() == resource.data.email.lower()
      );
      allow create: if true; // Public registration
      allow update, delete: if isSignedIn() && (
        isClubOwner(resource.data.clubId) || 
        request.auth.token.email.lower() == resource.data.email.lower()
      );
    }

    match /checkins/{checkInId} {
      allow read: if isSignedIn();
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    // Sponsors - Isolated
    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if isSignedIn() && (
        (resource != null && isClubOwner(resource.data.clubId)) ||
        (resource == null && isClubOwner(request.resource.data.clubId))
      );
    }

    // Promo Codes
    match /promocodes/{codeId} {
      allow read: if true; 
      allow write: if isAdmin(); 
    }
  }
}
