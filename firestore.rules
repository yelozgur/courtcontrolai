
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email.lower() == 'admin@deneme.com'
      );
    }

    function isClubOwner(clubId) {
      return isSignedIn() && get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid;
    }

    // User Profiles: Private read/write, Admin global oversight
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Clubs: Anyone can read branding, only owner or admin can update
    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if request.auth.uid == resource.data.ownerId || isAdmin();
      allow delete: if isAdmin();
    }

    // Tournaments: Public Read (Feed/Registration), Owner/Admin Write
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isClubOwner(resource.data.clubId) || isAdmin();
      allow delete: if isClubOwner(resource.data.clubId) || isAdmin();
    }

    // Matches: Public Read (Live Arena), Referees/Owners/Admins Write
    match /matches/{matchId} {
      allow read: if true;
      // Note: matches are linked to clubId
      allow write: if isSignedIn() || isAdmin(); 
    }

    // Participants: Public registration (Create), Owner/Admin management (Read/Update/Delete)
    match /participants/{participantId} {
      allow read: if true;
      allow create: if true; // Allows anyone to register
      allow update, delete: if isSignedIn() || isAdmin();
    }

    // Check-ins: Venue scanners can create, Staff can read
    match /checkins/{checkInId} {
      allow read: if isSignedIn() || isAdmin();
      allow create: if true; // Anyone scanning the venue QR
    }

    // Sponsors: Public read, Owner/Admin write
    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    // Promo Codes: Global read for validation, Admin only management
    match /promocodes/{codeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
