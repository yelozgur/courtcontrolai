rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isClubOwner(clubId) {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/clubs/$(clubId)) && 
         get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid) || 
        isAdmin()
      );
    }

    // --- Validation Functions ---
    function isValidTournament(data) {
      return data.keys().hasOnly(['clubId', 'name', 'startDate', 'endDate', 'sport', 'status', 'createdAt', 'description', 'numCourts', 'matchDuration', 'recoveryTime', 'referees', 'categories', 'entryFee', 'hasWelcomePack', 'welcomePackDescription', 'requiresSize', 'isFeatured', 'imageUrl']) &&
             data.clubId is string && data.name is string && data.status in ['draft', 'registration', 'active', 'completed'];
    }

    function isValidMatch(data) {
      return data.keys().hasOnly(['clubId', 'tournamentId', 'court', 'location', 'categoryId', 'category', 'teamA', 'teamB', 'status', 'startTime', 'completedAt']) &&
             data.clubId is string && data.tournamentId is string && data.status in ['scheduled', 'live', 'completed'];
    }

    function isValidParticipant(data) {
      return data.keys().hasOnly(['clubId', 'tournamentId', 'categoryId', 'categoryName', 'name', 'email', 'skillLevel', 'telegramHandle', 'verified', 'paymentStatus', 'paidAmount', 'packSize', 'createdAt', 'userId']) &&
             data.clubId is string && data.tournamentId is string && data.email is string;
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['email', 'displayName', 'role', 'photoURL', 'createdAt', 'updatedAt']) &&
             data.email is string && data.role in ['admin', 'club_owner', 'referee', 'player'];
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && isValidUser(request.resource.data);
    }

    match /clubs/{clubId} {
      allow read: if true; 
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /tournaments/{tournamentId} {
      allow read: if true; 
      allow create: if isSignedIn() && isClubOwner(request.resource.data.clubId) && isValidTournament(request.resource.data);
      allow update, delete: if isSignedIn() && (isClubOwner(resource.data.clubId) || isAdmin());
    }

    match /matches/{matchId} {
      allow read: if true; 
      allow write: if isSignedIn() && (
        (resource == null && isClubOwner(request.resource.data.clubId) && isValidMatch(request.resource.data)) ||
        (resource != null && isClubOwner(resource.data.clubId)) ||
        isAdmin()
      );
    }

    match /participants/{participantId} {
      allow read: if true; 
      allow create: if (request.resource.data.tournamentId != null) && 
                      exists(/databases/$(database)/documents/tournaments/$(request.resource.data.tournamentId)) &&
                      isValidParticipant(request.resource.data); 
      allow update, delete: if isSignedIn() && (
        isClubOwner(resource.data.clubId) || 
        (resource.data.userId == request.auth.uid) ||
        isAdmin()
      );
    }

    match /checkins/{checkInId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin();
    }

    match /courts/{courtId} {
      allow read: if true;
      allow write: if isSignedIn() && isClubOwner(request.resource.data.clubId);
    }

    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if isSignedIn() && (
        (resource == null && isClubOwner(request.resource.data.clubId)) ||
        (resource != null && isClubOwner(resource.data.clubId)) ||
        isAdmin()
      );
    }

    match /promocodes/{codeId} {
      allow read: if true; 
      allow write: if isAdmin(); 
    }
  }
}
