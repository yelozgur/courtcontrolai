
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email.lower() == 'admin@deneme.com'
      );
    }

    function isClubOwner(clubId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid || isAdmin()
      );
    }

    function isStaff(clubId) {
      // For now, staff = owner or admin. Extendable to 'referee' role check.
      return isClubOwner(clubId);
    }

    // User Profiles
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Clubs
    match /clubs/{clubId} {
      allow read: if true; // Public branding access
      allow create: if isSignedIn();
      allow update: if request.auth.uid == resource.data.ownerId || isAdmin();
      allow delete: if isAdmin();
    }

    // Tournaments
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isClubOwner(resource.data.clubId);
    }

    // Matches
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isSignedIn(); // Allows refereeHub updates and AI scheduling
    }

    // Participants & Check-ins (The high-volume operational paths)
    match /participants/{participantId} {
      allow read: if isSignedIn(); // Allow searching roster for check-in validation
      allow create: if true; // Public registration
      allow update, delete: if isSignedIn();
    }

    match /checkins/{checkInId} {
      allow read: if isSignedIn();
      allow create: if true; // Public self-check-in scanning
      allow update, delete: if isAdmin();
    }

    // Sponsors
    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Promo Codes
    match /promocodes/{codeId} {
      allow read: if true; // Validation read
      allow write: if isAdmin(); // Admin only management
    }
  }
}
