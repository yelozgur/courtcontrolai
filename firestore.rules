
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email.lower() == 'admin@deneme.com'
      );
    }

    function isClubOwner(clubId) {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/clubs/$(clubId)) && get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid) || 
        isAdmin()
      );
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // Clubs
    match /clubs/{clubId} {
      allow read: if true; // Required for public branding and internal checks
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Tournaments - Fixed: Always allow read (list/get) for public access
    match /tournaments/{tournamentId} {
      allow read: if true; 
      allow create: if isSignedIn(); 
      allow update, delete: if isSignedIn() && (isClubOwner(resource.data.clubId) || isAdmin());
    }

    // Matches - Fixed: Always allow read for public results
    match /matches/{matchId} {
      allow read: if true; 
      allow write: if isSignedIn() && (
        (resource == null && isClubOwner(request.resource.data.clubId)) ||
        (resource != null && isClubOwner(resource.data.clubId)) ||
        isAdmin()
      );
    }

    // Participants & Check-ins
    match /participants/{participantId} {
      allow read: if true; 
      allow create: if true; 
      allow update, delete: if isSignedIn() && (
        isClubOwner(resource.data.clubId) || 
        request.auth.token.email.lower() == resource.data.email.lower() ||
        isAdmin()
      );
    }

    match /checkins/{checkInId} {
      allow read: if isSignedIn();
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    // Sponsors
    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if isSignedIn() && (
        (resource == null && isClubOwner(request.resource.data.clubId)) ||
        (resource != null && isClubOwner(resource.data.clubId)) ||
        isAdmin()
      );
    }

    // Promo Codes
    match /promocodes/{codeId} {
      allow read: if true; 
      allow write: if isAdmin(); 
    }
  }
}
