rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Authentication Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    // BREAK RECURSION: Use a simple document existence check instead of a complex role-based loop.
    function isClubAdmin(clubId) {
      let clubPath = /databases/$(database)/documents/clubs/$(clubId);
      return isSignedIn() && exists(clubPath) && (
        get(clubPath).data.ownerId == request.auth.uid || 
        request.auth.uid in get(clubPath).data.get('adminIds', [])
      );
    }

    function isAdmin() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSignedIn() && exists(userPath) && get(userPath).data.role == 'admin';
    }

    // --- Validation Helpers ---
    function isValidTournament(data) {
      let allowedStatuses = ['draft', 'registration_open', 'registration_closed', 'in_progress', 'completed', 'archived'];
      return data.keys().hasAll(['clubId', 'name', 'status']) &&
             data.status in allowedStatuses;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isClubAdmin(clubId) || isAdmin();
    }

    match /tournaments/{tournamentId} {
      // Global Read for public listings
      allow read: if true;
      allow create: if isSignedIn() && (isClubAdmin(request.resource.data.clubId) || isAdmin());
      allow update: if isSignedIn() && (isClubAdmin(resource.data.clubId) || isAdmin());
      allow delete: if isAdmin();

      // --- Tournament subcollections ---
      // Categories (men's singles, mixed doubles, etc.)
      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isSignedIn() && (isClubAdmin(get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.clubId) || isAdmin());
      }

      // Registrations (player signups)
      match /registrations/{registrationId} {
        // CourtControl AI: read public (REST API, leaderboard)
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isClubAdmin(get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.clubId) || isAdmin();
      }

      // Brackets (R1, R2, R3, Final match tree)
      match /brackets/{bracketId} {
        allow read: if true;
        allow write: if isSignedIn() && (isClubAdmin(get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.clubId) || isAdmin());
      }

      // Matches (individual game instances)
      match /matches/{matchId} {
        allow read: if true;
        allow write: if isSignedIn() && (isClubAdmin(get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.clubId) || isAdmin());
      }
    }

    // Player ratings (ELO scores)
    match /ratings/{userId} {
      // CourtControl AI: read public (REST API public fetch) — yalnizca
      // authenticated yazma (sahiplik).
      allow read: if true;
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      // CourtControl AI: read public (REST API, leaderboard/bracket/results sayfalari)
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /participants/{participantId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn() && (isClubAdmin(resource.data.clubId) || isAdmin());
    }

    match /courts/{courtId} {
      allow read: if true;
      allow write: if isSignedIn() && (isClubAdmin(request.resource.data.clubId) || isAdmin());
    }

    match /promocodes/{promoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /sponsors/{sponsorId} {
      allow read: if true;
      allow write: if isSignedIn() && (isClubAdmin(request.resource.data.clubId) || isAdmin());
    }

    match /checkins/{checkinId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}
