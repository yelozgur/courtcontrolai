{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "A sports tournament entity",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "sport": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "finished"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "startDate", "sport", "status"]
    },
    "Match": {
      "title": "Match",
      "description": "An individual game or match in a tournament",
      "type": "object",
      "properties": {
        "tournamentId": { "type": "string" },
        "court": { "type": "number" },
        "category": { "type": "string" },
        "teamA": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number" },
            "players": { "type": "array", "items": { "type": "string" } }
          }
        },
        "teamB": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number" },
            "players": { "type": "array", "items": { "type": "string" } }
          }
        },
        "status": { "type": "string", "enum": ["scheduled", "live", "completed"] },
        "startTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" }
      },
      "required": ["tournamentId", "court", "status"]
    },
    "Club": {
      "title": "Club",
      "description": "Information about the sports club",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "numCourts": { "type": "number" },
        "logoUrl": { "type": "string" }
      },
      "required": ["name", "contactEmail"]
    },
    "Participant": {
      "title": "Participant",
      "description": "A player registered for tournaments",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telegramHandle": { "type": "string" },
        "skillLevel": { "type": "string", "enum": ["beginner", "intermediate", "pro"] },
        "registeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": {
      "schema": "Tournament",
      "description": "Collection of tournaments"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Collection of individual matches"
    },
    "/clubs/{clubId}": {
      "schema": "Club",
      "description": "Club profile information"
    },
    "/participants/{participantId}": {
      "schema": "Participant",
      "description": "Global list of club participants"
    }
  }
}