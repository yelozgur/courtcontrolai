
{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "A sports tournament entity. Publicly readable. Writeable by the club owner whose clubId matches the document's clubId.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string", "description": "The ID of the club that owns this tournament" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "sport": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "finished"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "numCourts": { "type": "number" },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "format": { "type": "string" },
              "sets": { "type": "number" },
              "ageGroup": { "type": "string" },
              "isTeamBased": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["clubId", "name", "startDate", "sport", "status"]
    },
    "Match": {
      "title": "Match",
      "description": "An individual match. Readable by all. Writeable by users who own the club associated with this match (clubId).",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "court": { "type": "number" },
        "category": { "type": "string" },
        "teamA": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number" },
            "setsWon": { "type": "number" },
            "players": { "type": "array", "items": { "type": "string" } }
          }
        },
        "teamB": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number" },
            "setsWon": { "type": "number" },
            "players": { "type": "array", "items": { "type": "string" } }
          }
        },
        "status": { "type": "string", "enum": ["scheduled", "live", "completed"] },
        "startTime": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clubId", "tournamentId", "status"]
    },
    "Club": {
      "title": "Club",
      "description": "Sports club profile. Publicly readable. Writeable only by the user whose auth.uid matches ownerId.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "The UID of the user who owns this club" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "contactEmail": { "type": "string" },
        "numCourts": { "type": "number" },
        "primarySport": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name"]
    },
    "User": {
      "title": "User",
      "description": "User profile. Readable and writeable only by the user themselves (auth.uid == userId). Admins have global read access.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Participant": {
      "title": "Participant",
      "description": "Tournament player. Publicly readable. Writeable by club owners or the participant themselves.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "telegramHandle": { "type": "string" },
        "skillLevel": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clubId", "tournamentId", "name", "email"]
    },
    "Sponsor": {
      "title": "Sponsor",
      "description": "Club partner. Publicly readable. Writeable by the club owner.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "tier": { "type": "string", "enum": ["gold", "silver", "bronze"] },
        "logoUrl": { "type": "string" }
      },
      "required": ["clubId", "name", "tier"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": { "schema": "Tournament", "description": "Global tournament registry" },
    "/matches/{matchId}": { "schema": "Match", "description": "Match score records" },
    "/clubs/{clubId}": { "schema": "Club", "description": "Sports organization profiles" },
    "/users/{userId}": { "schema": "User", "description": "Individual user accounts" },
    "/participants/{participantId}": { "schema": "Participant", "description": "Tournament entries" },
    "/sponsors/{sponsorId}": { "schema": "Sponsor", "description": "Club partnership details" }
  }
}
