
{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "A sports tournament entity",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "sport": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "finished"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "numCourts": { "type": "number" },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "format": { "type": "string" },
              "sets": { "type": "number" },
              "ageGroup": { "type": "string" },
              "isTeamBased": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["clubId", "name", "startDate", "sport", "status"]
    },
    "Match": {
      "title": "Match",
      "description": "An individual match in a tournament",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "court": { "type": "number" },
        "category": { "type": "string" },
        "teamA": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number" },
            "setsWon": { "type": "number" },
            "players": { "type": "array", "items": { "type": "string" } }
          }
        },
        "teamB": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number" },
            "setsWon": { "type": "number" },
            "players": { "type": "array", "items": { "type": "string" } }
          }
        },
        "status": { "type": "string", "enum": ["scheduled", "live", "completed"] },
        "startTime": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clubId", "tournamentId", "status"]
    },
    "Club": {
      "title": "Club",
      "description": "Information about the sports club",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "contactEmail": { "type": "string" },
        "numCourts": { "type": "number" },
        "primarySport": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name"]
    },
    "User": {
      "title": "User",
      "description": "User profile record",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": { "schema": "Tournament", "description": "Collection of tournaments" },
    "/matches/{matchId}": { "schema": "Match", "description": "Collection of individual matches" },
    "/clubs/{clubId}": { "schema": "Club", "description": "Club profile information" },
    "/users/{userId}": { "schema": "User", "description": "User profiles and roles" }
  }
}
