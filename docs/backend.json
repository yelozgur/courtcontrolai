
{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "Global tournament registry. STAGES: Draft, Registration, Live, Completed.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "locations": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "numCourts": { "type": "number" }
            }
          } 
        },
        "sport": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "registration", "active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "numCourts": { "type": "number", "description": "Total summed courts across all locations" },
        "matchDuration": { "type": "number", "description": "Duration in minutes" },
        "recoveryTime": { "type": "number", "description": "Buffer between matches in minutes" },
        "referees": { "type": "array", "items": { "type": "string" } },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "format": { "type": "string" },
              "sets": { "type": "number" },
              "ageGroup": { "type": "string" },
              "isTeamBased": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["clubId", "name", "startDate", "sport", "status"]
    },
    "Match": {
      "title": "Match",
      "description": "Operational match records linked to court/time.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "court": { "type": "number" },
        "location": { "type": "string" },
        "categoryId": { "type": "string" },
        "teamA": { "type": "object" },
        "teamB": { "type": "object" },
        "status": { "type": "string", "enum": ["scheduled", "live", "completed"] },
        "startTime": { "type": "string", "format": "date-time" }
      }
    },
    "Participant": {
      "title": "Participant",
      "description": "Registered player for a tournament.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "skillLevel": { "type": "string" },
        "telegramHandle": { "type": "string" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Club": {
      "title": "Club",
      "description": "Organization hosting tournaments.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "contactEmail": { "type": "string" },
        "numCourts": { "type": "number" },
        "primarySport": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CheckIn": {
      "title": "CheckIn",
      "description": "Day-of arrival verification.",
      "type": "object",
      "properties": {
        "participantId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "location": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Sponsor": {
      "title": "Sponsor",
      "description": "Brand partners for clubs or specific tournaments.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string", "description": "Optional: link sponsor to a specific event" },
        "name": { "type": "string" },
        "tier": { "type": "string", "enum": ["gold", "silver", "bronze"] },
        "websiteUrl": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": { "schema": "Tournament", "description": "Global Read. Auth Write." },
    "/matches/{matchId}": { "schema": "Match", "description": "Global Read. Auth Write." },
    "/clubs/{clubId}": { "schema": "Club", "description": "Global Read. Auth Write." },
    "/users/{userId}": { "schema": "User", "description": "Private Read/Write. Admin global." },
    "/participants/{participantId}": { "schema": "Participant", "description": "Global Read. Public Create." },
    "/checkins/{checkInId}": { "schema": "CheckIn", "description": "Global Read. Public Create." },
    "/sponsors/{sponsorId}": { "schema": "Sponsor", "description": "Global Read. Auth Write." }
  }
}
