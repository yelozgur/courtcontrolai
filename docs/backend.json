
{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "Global tournament registry. PERMISSIONS: Publicly readable and listable. Writable by club owner or admin.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "locations": { "type": "array", "items": { "type": "string" } },
        "sport": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "finished"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "numCourts": { "type": "number" },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "format": { "type": "string" },
              "sets": { "type": "number" },
              "ageGroup": { "type": "string" },
              "isTeamBased": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["clubId", "name", "startDate", "sport", "status"]
    },
    "Match": {
      "title": "Match",
      "description": "Match records. Publicly readable and listable. Writable by club owner or admin.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "court": { "type": "number" },
        "category": { "type": "string" },
        "teamA": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number" },
            "setsWon": { "type": "number" },
            "players": { "type": "array", "items": { "type": "string" } }
          }
        },
        "teamB": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number" },
            "setsWon": { "type": "number" },
            "players": { "type": "array", "items": { "type": "string" } }
          }
        },
        "status": { "type": "string", "enum": ["scheduled", "live", "completed"] },
        "startTime": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clubId", "tournamentId", "status"]
    },
    "Club": {
      "title": "Club",
      "description": "Club profiles. Publicly readable and listable. Writable by ownerId or admin.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "contactEmail": { "type": "string" },
        "numCourts": { "type": "number" },
        "primarySport": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name"]
    },
    "User": {
      "title": "User",
      "description": "User profile. Admin (admin@deneme.com) has global list/get access.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Participant": {
      "title": "Participant",
      "description": "Tournament entries. Publicly readable and listable. Writable by participant, club owner, or admin.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "telegramHandle": { "type": "string" },
        "skillLevel": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clubId", "tournamentId", "name", "email"]
    },
    "CheckIn": {
      "title": "Check-In",
      "description": "Arrival confirmation at venue. Publicly readable and listable. Writable by any user for check-in creation.",
      "type": "object",
      "properties": {
        "participantId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "location": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["participantId", "tournamentId", "timestamp"]
    },
    "Sponsor": {
      "title": "Sponsor",
      "description": "Partners. Publicly readable and listable. Writable by club owner or admin.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "tier": { "type": "string", "enum": ["gold", "silver", "bronze"] },
        "logoUrl": { "type": "string" }
      },
      "required": ["clubId", "name", "tier"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": { "schema": "Tournament", "description": "Global List/Get: Public. Write: Owner/Admin." },
    "/matches/{matchId}": { "schema": "Match", "description": "Global List/Get: Public. Write: Owner/Admin." },
    "/clubs/{clubId}": { "schema": "Club", "description": "Global List/Get: Public. Write: Owner/Admin." },
    "/users/{userId}": { "schema": "User", "description": "List/Get: Admin only. Get/Write: Self." },
    "/participants/{participantId}": { "schema": "Participant", "description": "Global List/Get: Public. Write: Public Create. Edit: Owner/Admin." },
    "/checkins/{checkInId}": { "schema": "CheckIn", "description": "Global List/Get: Public. Write: Public Create. Edit: Owner/Admin." },
    "/sponsors/{sponsorId}": { "schema": "Sponsor", "description": "Global List/Get: Public. Write: Owner/Admin." }
  }
}

    