
{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "Global tournament registry with lifecycle management.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "registration_open", "registration_closed", "in_progress", "completed", "archived"] },
        "statusHistory": { "type": "array", "items": { "type": "object" } },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "minParticipants": { "type": "number" },
        "maxParticipants": { "type": "number" },
        "bracketConfirmed": { "type": "boolean", "default": false },
        "entryFee": { "type": "number" },
        "sport": { "type": "string" },
        "locations": { "type": "array", "items": { "type": "object" } },
        "categories": { "type": "array", "items": { "type": "object" } },
        "version": { "type": "number", "default": 1 },
        "deletedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clubId", "name", "status"]
    },
    "Match": {
      "title": "Match",
      "description": "Structured match records for bracket progression.",
      "type": "object",
      "properties": {
        "tournamentId": { "type": "string" },
        "clubId": { "type": "string" },
        "round": { "type": "number" },
        "bracketPosition": { "type": "number" },
        "nextMatchId": { "type": "string" },
        "isBye": { "type": "boolean", "default": false },
        "byePlayerId": { "type": "string" },
        "courtId": { "type": "string" },
        "court": { "type": "number" },
        "teamA": { "type": "object" },
        "teamB": { "type": "object" },
        "score": {
          "type": "object",
          "properties": {
            "sets": { "type": "array", "items": { "type": "object" } },
            "winner": { "type": "string", "enum": ["teamA", "teamB"] },
            "walkover": { "type": "boolean", "default": false }
          }
        },
        "status": { "type": "string", "enum": ["scheduled", "live", "completed"] },
        "scheduledTime": { "type": "string", "format": "date-time" },
        "actualStartTime": { "type": "string", "format": "date-time" },
        "actualEndTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "version": { "type": "number", "default": 1 }
      }
    },
    "Participant": {
      "title": "Participant",
      "description": "Tournament attendee with ranking data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "clubId": { "type": "string" },
        "registrationStatus": { "type": "string", "enum": ["registered", "waitlisted", "withdrawn"] },
        "rating": { "type": "number", "default": 1000 },
        "ratingDelta": { "type": "number", "default": 0 },
        "name": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "Court": {
      "title": "Court",
      "description": "Physical facility resources.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "surface": { "type": "string", "enum": ["hard", "clay", "grass", "indoor"] },
        "status": { "type": "string", "enum": ["available", "occupied", "maintenance"] },
        "currentMatchId": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app delivery record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" },
        "relatedId": { "type": "string" },
        "relatedType": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": { "schema": "Tournament", "description": "Global Read. Club Admin Write." },
    "/matches/{matchId}": { "schema": "Match", "description": "Structured bracket records." },
    "/participants/{participantId}": { "schema": "Participant", "description": "Scoped by UID/Admin." },
    "/courts/{courtId}": { "schema": "Court", "description": "Facility registry." },
    "/users/{userId}/notifications/{notifId}": { "schema": "Notification", "description": "Private audit trail." }
  }
}
