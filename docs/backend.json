
{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "Global tournament registry. STAGES: Draft, Registration, Live, Completed.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "entryFee": { "type": "number", "description": "Price in USD for registration. Min $5.00 for paid events." },
        "isFeatured": { "type": "boolean", "default": false },
        "hasWelcomePack": { "type": "boolean", "default": false },
        "welcomePackDescription": { "type": "string" },
        "requiresSize": { "type": "boolean", "default": false },
        "locations": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "numCourts": { "type": "number" }
            }
          } 
        },
        "sport": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "registration", "active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "numCourts": { "type": "number" },
        "matchDuration": { "type": "number" },
        "recoveryTime": { "type": "number" },
        "referees": { "type": "array", "items": { "type": "string" } },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "format": { "type": "string" },
              "sets": { "type": "number" },
              "ageGroup": { "type": "string" },
              "isTeamBased": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["clubId", "name", "startDate", "sport", "status"]
    },
    "Match": {
      "title": "Match",
      "description": "Operational match records linked to court/time.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "court": { "type": "number" },
        "location": { "type": "string" },
        "categoryId": { "type": "string" },
        "category": { "type": "string" },
        "teamA": { "type": "object" },
        "teamB": { "type": "object" },
        "status": { "type": "string", "enum": ["scheduled", "live", "completed"] },
        "startTime": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Participant": {
      "title": "Participant",
      "description": "Registered player for a tournament with accounting and merchandising data.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "skillLevel": { "type": "string" },
        "telegramHandle": { "type": "string" },
        "verified": { "type": "boolean" },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid", "waived"] },
        "paidAmount": { "type": "number" },
        "packSize": { "type": "string", "description": "Selected size for welcome pack apparel" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Club": {
      "title": "Club",
      "description": "Organization hosting tournaments.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "timezone": { "type": "string", "default": "UTC" },
        "contactEmail": { "type": "string" },
        "numCourts": { "type": "number" },
        "primarySport": { "type": "string" },
        "logoUrl": { "type": "string" },
        "telegramBotToken": { "type": "string" },
        "telegramBotUsername": { "type": "string" },
        "aiUsageCount": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CheckIn": {
      "title": "CheckIn",
      "description": "Day-of arrival verification.",
      "type": "object",
      "properties": {
        "participantId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "location": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Sponsor": {
      "title": "Sponsor",
      "description": "Brand partners for clubs or specific tournaments.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "name": { "type": "string" },
        "tier": { "type": "string", "enum": ["gold", "silver", "bronze"] },
        "websiteUrl": { "type": "string" },
        "logoUrl": { "type": "string" }
      }
    },
    "PromoCode": {
      "title": "PromoCode",
      "description": "Platform-wide marketing discounts for SaaS fees.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discountPercent": { "type": "number" },
        "active": { "type": "boolean" },
        "expiryDate": { "type": "string", "format": "date" }
      }
    },
    "User": {
      "title": "User",
      "description": "System user account.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "club_owner", "referee", "player"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": { "schema": "Tournament", "description": "Global Read. Club Owner / Admin Write." },
    "/matches/{matchId}": { "schema": "Match", "description": "Global Read. Referee / Club Owner / Admin Write." },
    "/clubs/{clubId}": { "schema": "Club", "description": "Global Read (Branding). Owner / Admin Write." },
    "/users/{userId}": { "schema": "User", "description": "Private Read/Write. Admin global read." },
    "/participants/{participantId}": { "schema": "Participant", "description": "Staff Read/Update. Public Create." },
    "/checkins/{checkInId}": { "schema": "CheckIn", "description": "Staff Read. Public Create (Arrival)." },
    "/sponsors/{sponsorId}": { "schema": "Sponsor", "description": "Global Read. Club Owner / Admin Write." },
    "/promocodes/{codeId}": { "schema": "PromoCode", "description": "Admin Manage Only." }
  }
}
