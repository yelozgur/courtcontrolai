
{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "Global tournament registry. PUBLICLY READABLE AND LISTABLE FOR ALL VISITORS. Writable ONLY by the owner of the associated club (verified by clubId reference).",
      "type": "object",
      "properties": {
        "clubId": { "type": "string", "description": "The ID of the club that owns this tournament" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "sport": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "finished"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "numCourts": { "type": "number" },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "format": { "type": "string" },
              "sets": { "type": "number" },
              "ageGroup": { "type": "string" },
              "isTeamBased": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["clubId", "name", "startDate", "sport", "status"]
    },
    "Match": {
      "title": "Match",
      "description": "Match records. PUBLICLY READABLE AND LISTABLE FOR ALL VISITORS. Writable ONLY by the club owner managing the tournament (verified by clubId).",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "court": { "type": "number" },
        "category": { "type": "string" },
        "teamA": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number" },
            "setsWon": { "type": "number" },
            "players": { "type": "array", "items": { "type": "string" } }
          }
        },
        "teamB": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "score": { "type": "number" },
            "setsWon": { "type": "number" },
            "players": { "type": "array", "items": { "type": "string" } }
          }
        },
        "status": { "type": "string", "enum": ["scheduled", "live", "completed"] },
        "startTime": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clubId", "tournamentId", "status"]
    },
    "Club": {
      "title": "Club",
      "description": "Club profiles. GLOBAL READ AND LIST ACCESS FOR ALL USERS. Writable ONLY by the owner (ownerId == auth.uid).",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "The UID of the user who owns this club" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "contactEmail": { "type": "string" },
        "numCourts": { "type": "number" },
        "primarySport": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name"]
    },
    "User": {
      "title": "User",
      "description": "User profile. READ/WRITE by the owner only. Platform admins have global READ access. Private collection.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" },
        "clubId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Participant": {
      "title": "Participant",
      "description": "Tournament entries. PUBLICLY READABLE AND LISTABLE. Writable by the participant themselves or the club owner managing the event.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "telegramHandle": { "type": "string" },
        "skillLevel": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clubId", "tournamentId", "name", "email"]
    },
    "Sponsor": {
      "title": "Sponsor",
      "description": "Partners. PUBLICLY READABLE AND LISTABLE. Writable only by the club owner.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "websiteUrl": { "type": "string" },
        "tier": { "type": "string", "enum": ["gold", "silver", "bronze"] },
        "logoUrl": { "type": "string" }
      },
      "required": ["clubId", "name", "tier"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": { "schema": "Tournament", "description": "Public tournament registry. Allow 'get' and 'list' for all. Writable by club owner." },
    "/matches/{matchId}": { "schema": "Match", "description": "Match scores. Allow 'get' and 'list' for all. Writable by club owner." },
    "/clubs/{clubId}": { "schema": "Club", "description": "Organizations. MUST ALLOW 'get' and 'list' for ALL visitors. Writable by ownerId." },
    "/users/{userId}": { "schema": "User", "description": "Private profile. Owner read/write only." },
    "/participants/{participantId}": { "schema": "Participant", "description": "Registrations. Allow 'get' and 'list' for all. Writable by participant/owner." },
    "/sponsors/{sponsorId}": { "schema": "Sponsor", "description": "Partnership info. Allow 'get' and 'list' for all. Writable by club owner." }
  }
}
