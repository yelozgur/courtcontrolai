
{
  "entities": {
    "Tournament": {
      "title": "Tournament",
      "description": "Global tournament registry. STAGES: Draft, Registration, Live, Completed.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "locations": { "type": "array", "items": { "type": "string" } },
        "sport": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "registration", "active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "numCourts": { "type": "number" },
        "referees": { "type": "array", "items": { "type": "string" }, "description": "User UIDs or emails" },
        "categories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "format": { "type": "string" },
              "sets": { "type": "number" },
              "ageGroup": { "type": "string" },
              "isTeamBased": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["clubId", "name", "startDate", "sport", "status"]
    },
    "Match": {
      "title": "Match",
      "description": "Operational match records linked to court/time.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "court": { "type": "number" },
        "location": { "type": "string" },
        "categoryId": { "type": "string" },
        "refereeId": { "type": "string" },
        "teamA": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "participantId": { "type": "string" },
            "score": { "type": "number" },
            "setsWon": { "type": "number" }
          }
        },
        "teamB": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "participantId": { "type": "string" },
            "score": { "type": "number" },
            "setsWon": { "type": "number" }
          }
        },
        "status": { "type": "string", "enum": ["scheduled", "live", "completed"] },
        "startTime": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clubId", "tournamentId", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile with roles.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["player", "referee", "club_owner", "admin"] },
        "clubId": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "skillLevel": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Participant": {
      "title": "Participant",
      "description": "Tournament roster entries.",
      "type": "object",
      "properties": {
        "clubId": { "type": "string" },
        "tournamentId": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "skillLevel": { "type": "string" },
        "categoryId": { "type": "string" },
        "isCheckedIn": { "type": "boolean" },
        "checkInLocation": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/tournaments/{tournamentId}": { "schema": "Tournament", "description": "Global Read. Auth Write." },
    "/matches/{matchId}": { "schema": "Match", "description": "Global Read. Auth Write." },
    "/clubs/{clubId}": { "schema": "Club", "description": "Global Read. Auth Write." },
    "/users/{userId}": { "schema": "User", "description": "Private Read/Write. Admin global." },
    "/participants/{participantId}": { "schema": "Participant", "description": "Global Read. Auth Write." },
    "/checkins/{checkInId}": { "schema": "CheckIn", "description": "Global Read. Public Create." }
  }
}
