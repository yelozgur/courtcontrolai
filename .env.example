# CourtControl AI — Environment Variables
# Bu dosya repoya commit edilir, gercek secret'ler icermez.
# Gercek degerler icin .env.local kullan (gitignore'da).

# === Firebase Emulator Mode (Local Dev) ===
# true ise Firestore + Auth localhost'a baglanir (8080, 9099).
# Prod'da bu satir olmamali veya false olmali.
NEXT_PUBLIC_USE_EMULATOR=true

# === Firebase config (gercek degerler prod'da) ===
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# === Genkit / Google AI ===
# Local gelistirmede genkit start -- tsx src/ai/dev.ts ile dev UI acilir.
# Mock LLM istiyorsan GOOGLE_GENAI_API_KEY bos birak (Genkit test mock'a duser).
GOOGLE_GENAI_API_KEY=your_google_ai_key

# === Telegram (opsiyonel, sadece production'da gerekli) ===
TELEGRAM_BOT_TOKEN=
